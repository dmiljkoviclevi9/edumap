{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Optional: when ConnectionString and CountriesBlobName are both set,
  // CountryRepository loads countries from Blob Storage instead of the
  // embedded Data/countries.json. Configure these in App Service ->
  // Configuration -> Application settings (or User Secrets locally) so
  // they don't get committed.
  "Storage": {
    "ConnectionString": "",
    "CountriesContainerName": "data",
    "CountriesBlobName": ""
  },

  // Optional: when ConnectionString is set, the app sends telemetry to
  // Application Insights. Configure via App Service / Container Apps app
  // settings (or APPLICATIONINSIGHTS_CONNECTION_STRING env var) to keep it
  // out of the repo.
  "ApplicationInsights": {
    "ConnectionString": ""
  }
}
